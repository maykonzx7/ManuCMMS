# =============================================================================
# ManuCMMS — exemplo de ambiente para homologacao / producao
# =============================================================================

NODE_ENV=production
PORT=3000

# URL pública do frontend autorizada a chamar a API.
# Separe múltiplas origens por vírgula.
CORS_ALLOWED_ORIGINS=https://app.exemplo.com

# --- Supabase Auth ---
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_JWT_SECRET=cole_o_jwt_secret_do_dashboard_aqui
SUPABASE_ANON_KEY=cole_a_anon_key_aqui

# --- PostgreSQL ---
# Use uma DATABASE_URL completa do provedor OU o host/senha do Supabase.
DATABASE_URL=postgresql://usuario:senha@host:5432/manucmms?sslmode=require
# SUPABASE_DB_HOST=db.SEU_PROJECT_REF.supabase.co
# SUPABASE_DB_PASSWORD=sua_senha_do_postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_PORT=5432

# --- MongoDB ---
MONGODB_URI=mongodb://usuario:senha@mongo:27017/manucmms?authSource=admin

# --- RabbitMQ ---
RABBITMQ_URL=amqp://usuario:senha@rabbitmq:5672/
