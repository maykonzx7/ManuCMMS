generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  TECNICO
  SUPERVISOR
  GESTOR
  AUDITOR
  ADMIN
}

model UnidadeFabril {
  id          String    @id @default(uuid()) @db.Uuid
  nome        String    @db.VarChar(100)
  localizacao String    @db.VarChar(255)
  usuarios    Usuario[]

  @@map("unidade_fabril")
}

/// Perfil corporativo local; autenticação fica no Supabase (`auth_sub` = JWT `sub`).
model Usuario {
  id         String          @id @default(uuid()) @db.Uuid
  authSub    String          @unique @map("auth_sub")
  idUnidade  String          @map("id_unidade") @db.Uuid
  unidade    UnidadeFabril   @relation(fields: [idUnidade], references: [id])
  nome       String          @db.VarChar(150)
  email      String          @unique @db.VarChar(100)
  perfil     PerfilUsuario
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@map("usuario")
}
