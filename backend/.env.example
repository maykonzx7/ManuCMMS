# =============================================================================
# ManuCMMS — API NestJS (copiar para backend/.env)
# =============================================================================
#   cp .env.example .env
# Suba antes os serviços: na raiz do repo, `docker compose up -d`.

PORT=3000
NODE_ENV=development

# Frontend autorizado a chamar a API.
# Em produção, separar múltiplas origens por vírgula.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# --- Supabase Auth (validação de JWT na API — NF-02) ---
# Project URL: Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
# JWT Secret: Dashboard → Project Settings → API → JWT Secret (não use anon key como segredo)
SUPABASE_JWT_SECRET=cole_o_jwt_secret_do_dashboard_aqui
# Alternativa de desenvolvimento: se o JWT Secret ainda não estiver configurado,
# a API pode validar o access token consultando o Supabase Auth com a anon key.
SUPABASE_ANON_KEY=cole_a_anon_key_aqui

# Primeiro login: cria linha em `usuario` com auth_sub = JWT sub (opcional)
# AUTH_BOOTSTRAP_UNIDADE_ID=<uuid da unidade padrão>
# AUTH_BOOTSTRAP_PERFIL=TECNICO

# --- PostgreSQL ---
# Opção A — Docker local (compose na raiz do repo):
DATABASE_URL=postgresql://manucmms:manucmms_dev@localhost:5432/manucmms
#
# Opção B — Supabase: comente DATABASE_URL acima e preencha (senha = Database password do Dashboard):
# SUPABASE_DB_HOST=db.SEU_PROJECT_REF.supabase.co
# SUPABASE_DB_PASSWORD=sua_senha_do_postgres
# (opcional) SUPABASE_DB_USER=postgres  SUPABASE_DB_NAME=postgres  SUPABASE_DB_PORT=5432
# A URL é montada com ?sslmode=require. Se DATABASE_URL estiver definida, ela tem prioridade.

# MongoDB — trilha de auditoria (authSource=admin com usuário root criado pelo compose)
MONGODB_URI=mongodb://manucmms:manucmms_dev@localhost:27017/manucmms?authSource=admin

# RabbitMQ — AMQP
RABBITMQ_URL=amqp://manucmms:manucmms_dev@localhost:5672/
