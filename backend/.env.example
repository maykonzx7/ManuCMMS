# =============================================================================
# ManuCMMS — API NestJS (copiar para backend/.env)
# =============================================================================
#   cp .env.example .env
# Suba antes os serviços: na raiz do repo, `docker compose up -d`.

PORT=3000

# --- Supabase Auth (validação de JWT na API — NF-02) ---
# Project URL: Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
# JWT Secret: Dashboard → Project Settings → API → JWT Secret (não use anon key como segredo)
SUPABASE_JWT_SECRET=cole_o_jwt_secret_do_dashboard_aqui

# Primeiro login: cria linha em `usuario` com auth_sub = JWT sub (opcional)
# AUTH_BOOTSTRAP_UNIDADE_ID=<uuid da unidade padrão>
# AUTH_BOOTSTRAP_PERFIL=TECNICO

# PostgreSQL (mesmas credenciais que docker-compose na raiz, se usar o padrão)
DATABASE_URL=postgresql://manucmms:manucmms_dev@localhost:5432/manucmms

# MongoDB — trilha de auditoria (authSource=admin com usuário root criado pelo compose)
MONGODB_URI=mongodb://manucmms:manucmms_dev@localhost:27017/manucmms?authSource=admin

# RabbitMQ — AMQP
RABBITMQ_URL=amqp://manucmms:manucmms_dev@localhost:5672/
