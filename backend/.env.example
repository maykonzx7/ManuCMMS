# =============================================================================
# ManuCMMS — API NestJS (copiar para backend/.env)
# =============================================================================
#   cp .env.example .env
# Suba antes os serviços: na raiz do repo, `docker compose up -d`.

PORT=3000

# PostgreSQL (mesmas credenciais que docker-compose na raiz, se usar o padrão)
DATABASE_URL=postgresql://manucmms:manucmms_dev@localhost:5432/manucmms

# MongoDB — trilha de auditoria (authSource=admin com usuário root criado pelo compose)
MONGODB_URI=mongodb://manucmms:manucmms_dev@localhost:27017/manucmms?authSource=admin

# RabbitMQ — AMQP
RABBITMQ_URL=amqp://manucmms:manucmms_dev@localhost:5672/
