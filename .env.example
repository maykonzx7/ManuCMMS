# =============================================================================
# ManuCMMS — variáveis para Docker Compose (raiz do repositório)
# =============================================================================
# Copie para .env na raiz para sobrescrever padrões:
#   cp .env.example .env
# Não commite o arquivo .env (já está no .gitignore).

# --- PostgreSQL (transacional / paridade Supabase em dev) ---
POSTGRES_USER=manucmms
POSTGRES_PASSWORD=manucmms_dev
POSTGRES_DB=manucmms
POSTGRES_PORT=5432

# --- MongoDB (auditoria — RN-04, NF-05) ---
MONGO_INITDB_ROOT_USERNAME=manucmms
MONGO_INITDB_ROOT_PASSWORD=manucmms_dev
MONGO_PORT=27017

# --- RabbitMQ (mensageria — NF-08) ---
RABBITMQ_DEFAULT_USER=manucmms
RABBITMQ_DEFAULT_PASS=manucmms_dev
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
